; Crimson Streets / The Dangerous Spain - clean Godot base
config_version=5

[application]
config/name="The Dangerous Spain V2"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]
move_forward={"deadzone":0.5,"events":[Object(InputEventKey,"device":-1,"keycode":87)]}
move_back={"deadzone":0.5,"events":[Object(InputEventKey,"device":-1,"keycode":83)]}
move_left={"deadzone":0.5,"events":[Object(InputEventKey,"device":-1,"keycode":65)]}
move_right={"deadzone":0.5,"events":[Object(InputEventKey,"device":-1,"keycode":68)]}
interact={"deadzone":0.5,"events":[Object(InputEventKey,"device":-1,"keycode":70)]}
run={"deadzone":0.5,"events":[Object(InputEventKey,"device":-1,"keycode":4194325)]}
open_map={"deadzone":0.5,"events":[Object(InputEventKey,"device":-1,"keycode":77)]}
open_console={"deadzone":0.5,"events":[Object(InputEventKey,"device":-1,"keycode":192)]}
accelerate={"deadzone":0.5,"events":[Object(InputEventKey,"device":-1,"keycode":87)]}
brake={"deadzone":0.5,"events":[Object(InputEventKey,"device":-1,"keycode":83)]}
steer_left={"deadzone":0.5,"events":[Object(InputEventKey,"device":-1,"keycode":65)]}
steer_right={"deadzone":0.5,"events":[Object(InputEventKey,"device":-1,"keycode":68)]}

[rendering]
renderer/rendering_method="forward_plus"
textures/default_filters/use_nearest_mipmap_filter=true
